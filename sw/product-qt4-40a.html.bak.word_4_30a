            <tr><td>Tupu / Kamili</td><td>400 × 150 × 200 mm</td><td>5</td><td>3,000 – 3,600</td></tr>
            <tr><td>Tupu / Kamili</td><td>400 × 100 × 200 mm</td><td>7</td><td>4,000 – 4,500</td></tr>
            <tr><td>Tupu / Kamili</td><td>390 × 120 × 190 mm</td><td>6</td><td>3,200 – 4,000</td></tr>
            <tr><td>Sahani ya sakafu</td><td>500 × 150 × 200 mm</td><td>5</td><td>3,000 – 3,600</td></tr>
            <tr><td>Ya kufunga (Uni / Mkate)</td><td>200 × 100 × 60 mm</td><td>14</td><td>8,000 – 9,500</td></tr>
            <tr><td>Ya kufunga (Wimbi)</td><td>225 × 112.5 × 60 mm</td><td>9</td><td>5,600 – 8,650</td></tr>
            <tr><td>Ya kufunga (8)</td><td>400 × 200 × 60 mm</td><td>4</td><td>2,400 – 3,000</td></tr>
