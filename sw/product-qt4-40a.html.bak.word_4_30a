          </tbody>
        </table>

        <h4 style="margin-top: 24px; color: var(--secondary);">③ Ukanda wa Conveyor wa Mita 6 (chaguo la ziada)</h4>
        <table class="spec-table">
          <tbody>
            <tr><th>Kigezo</th><th>Thamani</th></tr>
            <tr><td>Nguvu ya umeme</td><td>1.1 kW</td></tr>
            <tr><td>Uzito</td><td>260 kg</td></tr>
            <tr><td>Saizi</td><td>6000 × 770 × 700 mm</td></tr>
            <tr><td>Vipimo vya usafirishaji</td><td>3200 × 770 × 800 mm</td></tr>
